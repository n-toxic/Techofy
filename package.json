{
  "name": "techofy-cloud-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "shared/*"
  ],
  "scripts": {
    "install:all": "npm install --legacy-peer-deps",
    "build:frontend": "cd frontend && npm run build",
    "dev:frontend": "cd frontend && npm run dev",
    "deploy": "npm run build:frontend"
  },
  "dependencies": {
    "drizzle-zod": "^0.7.0",
    "drizzle-orm": "^0.43.0",
    "zod": "^3.24.2",
    "pg": "^8.16.0",
    "bcryptjs": "^3.0.3",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "esbuild": "0.25.0",
    "esbuild-plugin-pino": "^2.3.3",
    "tsx": "^4.19.4"
  },
  "overrides": {
    "esbuild": "0.25.0"
  }
}
