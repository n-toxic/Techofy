{
  "version": 2,
  "builds": [
    {
      "src": "backend/src/index.ts",
      "use": "@vercel/node",
      "config": { "includeFiles": ["shared/**"] }
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "backend/src/index.ts" },
    { "source": "/(.*)", "destination": "backend/src/index.ts" }
  ]
}
